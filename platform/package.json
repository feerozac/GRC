{
  "name": "secure-path",
  "version": "1.0.0",
  "description": "AI-powered compliance testing tool",
  "author": "Refat <nobilix@gmail.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <=22.x",
    "pnpm": "<=9.x"
  },
  "scripts": {
    "debug": "tsx --env-file=.env",
    "check:types": "tsc --noEmit",
    "build": "NODE_ENV=production cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation prettier",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "services:up": "docker compose -f compose.services.yaml --env-file .env.docker up -d",
    "services:down": "docker compose -f compose.services.yaml --env-file .env.docker down",
    "fetch-seeds": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/fetch-seeds.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@payloadcms/db-postgres": "^3.5.0",
    "@payloadcms/next": "^3.5.0",
    "@payloadcms/payload-cloud": "^3.5.0",
    "@payloadcms/richtext-lexical": "^3.5.0",
    "@payloadcms/ui": "^3.5.0",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@radix-ui/react-visually-hidden": "^1.1.2",
    "@tanstack/react-query": "^5.63.0",
    "@types/js-cookie": "^3.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "formdata-node": "^6.0.3",
    "graphql": "^16.8.1",
    "ioredis": "^5.4.1",
    "js-cookie": "^3.0.5",
    "js-tiktoken": "^1.0.19",
    "langfuse": "^3.31.1",
    "lucide-react": "^0.462.0",
    "minio": "^8.0.2",
    "next": "15.5.14",
    "next-themes": "^0.4.4",
    "openai": "^4.74.0",
    "payload": "^3.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.0.2",
    "sharp": "0.32.6",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "unstructured-client": "^0.18.2",
    "vaul": "^1.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@types/react": "npm:types-react@19.0.0-rc.1",
    "@types/react-dom": "npm:types-react-dom@19.0.0-rc.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "5.7.2"
  },
  "packageManager": "pnpm@9.15.0"
}
